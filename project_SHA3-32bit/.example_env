# To unset all of them run (on fish): set -n | string match -r '^SHA3_'

# This file contains environment variable definitions for the SHA3-32bit project.
# SHA3_INPUTS is the number of inputs stored in one dataset folder.
# In training, this also controls how many traces are expected per folder before multiplying by invocations.
SHA3_INPUTS=16

# SHA3_INVOCATIONS is the number of trace files per input message (one file per Keccak invocation).
# Increasing this value increases traces per folder and affects several downstream sizes.
SHA3_INVOCATIONS=10

# --- 0001_reference ---
# SHA3_REFERENCE_FOLDERS is the number of folders used when building the reference trace.
# Keep this equal to the number of available reference acquisitions.
SHA3_REFERENCE_FOLDERS=2

# SHA3_REFERENCE_TRACE_LEN is the raw sample length expected in reference traces.
# Set this to the exact sample count in your reference capture files.
SHA3_REFERENCE_TRACE_LEN=13824

# --- 0002_detection ---
# SHA3_DETECTION_TRACE_LEN is the raw sample length expected for detection traces.
# It must match the actual file length used in the detection phase.
SHA3_DETECTION_TRACE_LEN=13824

# SHA3_DETECTION_SET_COUNT is the number of detection folders/sets to process.
# Set this to the count of detection datasets you actually have.
SHA3_DETECTION_SET_COUNT=5

# SHA3_DETECTION_SETS_PER_PART is a packaging parameter for detection part_XX.hdf5 files.
# It controls how many detection sets are grouped per part and only affects chunking/I-O, not signal content.
SHA3_DETECTION_SETS_PER_PART=10

# SHA3_DETECTION_CORR_BOUND is the minimum allowed correlation between a detection trace and the reference trace.
# Lower this if valid simulated traces are rejected; keep it high only for very tightly aligned traces.
SHA3_DETECTION_CORR_BOUND=0.82

# SHA3_DETECTION_TRACE_OFFSET is the first raw sample index considered during detection preprocessing.
# Increase this to skip early trace regions before the useful leakage window starts.
SHA3_DETECTION_TRACE_OFFSET=0

# SHA3_DETECTION_PPC is the step in raw samples between consecutive extracted points.
# Larger values sample more sparsely across time, while smaller values keep denser temporal sampling.
SHA3_DETECTION_PPC=10

# SHA3_DETECTION_OUTPUT_SIZE is the number of extracted points per processed detection trace.
# This directly becomes the trace length stored in processed detection HDF5 files.
SHA3_DETECTION_OUTPUT_SIZE=1382

# SHA3_DETECTION_ROUNDS is the number of Keccak rounds considered in detection extraction/reporting.
SHA3_DETECTION_ROUNDS=4

# SHA3_DETECTION_ICS_WORDS_AB is the number of 32-bit words scanned for A/B tags per round.
SHA3_DETECTION_ICS_WORDS_AB=50

# SHA3_DETECTION_ICS_WORDS_CD is the number of 32-bit words scanned for C/D tags per round.
SHA3_DETECTION_ICS_WORDS_CD=10

# SHA3_DETECTION_ICS_THRESHOLDS is the comma-separated threshold list used by Code_extract_ics.
SHA3_DETECTION_ICS_THRESHOLDS=0.09,0.08,0.07,0.06,0.05,0.04,0.03,0.02,0.01

# SHA3_DETECTION_SAMPLE_SHIFT is an additional per-point offset applied before averaging each window.
# Use it to fine-align extraction windows to your trace timing without changing the global offset.
SHA3_DETECTION_SAMPLE_SHIFT=0

# SHA3_DETECTION_SAMPLE_WIDTH is the number of raw samples averaged for each extracted point.
# Larger widths smooth more noise but reduce local temporal detail.
SHA3_DETECTION_SAMPLE_WIDTH=1

# --- 0003_training ---
# SHA3_TRAINING_SET_COUNT is the number of training folders (Raw_TR_xxxx) to process.
# This controls overall training volume and the total number of traces downstream.
SHA3_TRAINING_SET_COUNT=10

# SHA3_TRAINING_TRACE_LEN is the raw sample length expected in each training trace file.
# Keep this aligned with the acquisition setup so bounds checks and derived windows are valid.
SHA3_TRAINING_TRACE_LEN=13824

# SHA3_TRAINING_TRACE_OFFSET is the first raw sample index used for feature extraction.
# Use this to skip unstable or uninformative prefix samples before the target activity starts.
SHA3_TRAINING_TRACE_OFFSET=0

# SHA3_TRAINING_PPC is the number of raw points aggregated into one compressed output point.
# Larger values smooth more and reduce temporal resolution; smaller values keep finer timing detail.
SHA3_TRAINING_PPC=1

# SHA3_TRAINING_OUTPUT_SIZE is the number of compressed points kept per processed trace.
# Together with offset and PPC, it defines the raw window: offset + output_size * ppc.
SHA3_TRAINING_OUTPUT_SIZE=13824

# SHA3_TRAINING_SETS_PER_PART is only a packaging/chunking parameter for part_XX.hdf5 files.
# It does not change signal content; it only controls how many training folders are grouped into each part file for storage and I/O convenience.
SHA3_TRAINING_SETS_PER_PART=10

# SHA3_TRAINING_CORR_BOUND is the minimum Pearson correlation allowed between each raw trace and the reference trace.
# Lower this if valid traces are rejected by quality filtering; increase it only if your traces are very tightly aligned.
SHA3_TRAINING_CORR_BOUND=0.82

# SHA3_TRAINING_ICS_LEVEL selects which extracted ICS archive is used by training IoP extraction.
# Example: 10 -> ics_original_010.zip, 20 -> ics_original_020.zip.
SHA3_TRAINING_ICS_LEVEL=70

# --- 0004_validation ---
# SHA3_VALIDATION_INPUTS is the number of inputs expected per validation folder.
# Set this to the exact count present in your validation datasets.
SHA3_VALIDATION_INPUTS=10

# SHA3_VALIDATION_SET_COUNT is the number of validation folders/sets to process.
# Set this to match your available validation data volume.
SHA3_VALIDATION_SET_COUNT=5

# SHA3_VALIDATION_TRACE_OFFSET is the first raw sample index used in validation preprocessing.
# Keep this aligned with where useful activity begins in your validation traces.
SHA3_VALIDATION_TRACE_OFFSET=0

# SHA3_VALIDATION_PPC is the number of raw samples aggregated per validation output point.
# Together with output size, this controls temporal resolution in validation traces.
SHA3_VALIDATION_PPC=1

# SHA3_VALIDATION_OUTPUT_SIZE is the number of processed points kept per validation trace.
# Keep this consistent with the template extraction geometry used downstream.
SHA3_VALIDATION_OUTPUT_SIZE=13824

# SHA3_VALIDATION_CORR_BOUND is the minimum allowed correlation in validation preprocessing.
# For the current simulated validation traces, values around 0.90 are realistic.
SHA3_VALIDATION_CORR_BOUND=0.90

# SHA3_VALIDATION_SETS_PER_PART controls how many validation sets are grouped into one part_XX.hdf5.
# Use smaller values for quicker iteration; larger values reduce part count.
SHA3_VALIDATION_SETS_PER_PART=10

# SHA3_VALIDATION_TEMPLATE_TAG selects ICS/template archives in 0004 template validation.
# Example: 10 -> ics_original_010.zip and templateLDA_O010.zip.
SHA3_VALIDATION_TEMPLATE_TAG=10

# SHA3_VALIDATION_ICS_TAG selects the ICS archive used by template validation.
# Keep this aligned with the ICS content used during template profiling.
SHA3_VALIDATION_ICS_TAG=70
# --- 0005_SASCA ---
# SHA3_SASCA_TRACE_COUNT is how many validation traces 0005_SASCA will process.
# Default in code is min(1000, available validation traces); set this explicitly if needed.
SHA3_SASCA_TRACE_COUNT=500

# SHA3_SASCA_TEMPLATE_TAG selects template archive templateLDA_OXXX.zip used in 0005.
SHA3_SASCA_TEMPLATE_TAG=10

# SHA3_SASCA_ICS_TAG selects ICS archive ics_original_XXX.zip used in 0005.
SHA3_SASCA_ICS_TAG=70

# SHA3_SASCA_PPC is the samples-per-ICS-point factor used in 0005 table generation.
SHA3_SASCA_PPC=10

# SHA3_SASCA_ITERATION_COUNT is the number of loopy-BP iterations for iteration scans.
SHA3_SASCA_ITERATION_COUNT=40

# SHA3_SASCA_RATE_BP_ITERATION_COUNT is the max loopy-BP iterations per rate point.
SHA3_SASCA_RATE_BP_ITERATION_COUNT=200

# SHA3_SASCA_RATE_POINT_COUNT is the number of points in the rate scan axis.
# With step_bits=8 and point_count=201, rates span 0..1600 unknown bits.
SHA3_SASCA_RATE_POINT_COUNT=201

# SHA3_SASCA_RATE_STEP_BITS is the spacing between consecutive rate scan points.
SHA3_SASCA_RATE_STEP_BITS=8

# SHA3_SASCA_ALLOWED_WRONG_BITS controls success criterion in scans.
# 0 means exact 1600-bit match, 1 allows one wrong bit, etc.
SHA3_SASCA_ALLOWED_WRONG_BITS=0

# SHA3_SASCA_OUTPUT_BITS defines the digest length used to derive known-rate bits.
# For SHA3-512 keep this at 512.
SHA3_SASCA_OUTPUT_BITS=512